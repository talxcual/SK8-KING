<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Neon Glow Outer Layer (Faint) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="5dp"
                android:color="#1AF5FF00" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    
    <!-- Neon Glow Middle Layer -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="3dp"
                android:color="#40F5FF00" />
            <corners android:radius="9dp" />
        </shape>
    </item>
    
    <!-- Core Border (Solid Neon Yellow) and Dark Fill -->
    <item android:left="2.5dp" android:top="2.5dp" android:right="2.5dp" android:bottom="2.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A" />
            <stroke
                android:width="2dp"
                android:color="@color/primary_accent" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
