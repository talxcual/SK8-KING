<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chess_floor"
    tools:context=".AuthActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingBottom="32dp">

            <!-- GIF LOGO: Gran protagonista -->
            <ImageView
                android:id="@+id/ivSk8KingGif"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="0dp"
                android:contentDescription="SK8KING logo"
                android:scaleType="fitCenter" />

            <!-- EMAIL LABEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/bebas_neue"
                android:letterSpacing="0.15"
                android:layout_marginTop="32dp"
                android:layout_marginStart="4dp" />

            <!-- EMAIL FIELD -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_neon_edittext"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:textColor="@color/white"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:importantForAutofill="yes" />

            <!-- PASSWORD LABEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTRASEÑA"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/bebas_neue"
                android:letterSpacing="0.15"
                android:layout_marginTop="12dp"
                android:layout_marginStart="4dp" />

            <!-- PASSWORD FIELD -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textPassword"
                android:background="@drawable/bg_neon_edittext"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:textColor="@color/white"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:importantForAutofill="yes" />

            <!-- INICIAR SESION BUTTON (YELLOW) -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="INICIAR SESIÓN"
                android:textColor="@color/black"
                android:backgroundTint="@color/primary_accent"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/bebas_neue"
                android:letterSpacing="0.1"
                app:cornerRadius="8dp"
                android:layout_marginTop="20dp" />

            <!-- OR SEPARATOR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#444444" />

                <TextView
                    android:id="@+id/orSeparator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  0  "
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#444444" />
            </LinearLayout>

            <!-- REGISTRAR BUTTON (OUTLINED) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="REGISTRAR"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/bebas_neue"
                android:letterSpacing="0.1"
                app:strokeColor="@color/white"
                app:strokeWidth="2dp"
                app:cornerRadius="8dp"
                android:layout_marginTop="16dp" />

            <!-- INICIAR SESION CON GOOGLE -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogleSignIn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="INICIAR SESIÓN CON GOOGLE"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:fontFamily="@font/bebas_neue"
                android:letterSpacing="0.05"
                app:backgroundTint="#1E1E1E"
                app:cornerRadius="8dp"
                android:layout_marginTop="10dp"
                app:icon="@drawable/ic_google_logo"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:iconTint="@null"
                app:iconPadding="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_auth_initial"
                android:textColor="#333333"
                android:textSize="10sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>